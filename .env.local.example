# Supabase project: https://supabase.com/dashboard/project/bzjcenxqanzrezviqnsw
# Settings -> API for these values.

# Public — safe to expose to the browser, protected by RLS.
NEXT_PUBLIC_SUPABASE_URL=https://bzjcenxqanzrezviqnsw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret — server-only, bypasses RLS. Used by scripts/seed.ts and the RSS
# ingestion pipeline. Never expose to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret required in the `x-ingest-secret` header to trigger
# POST /api/ingest (the RSS ingestion pipeline's remote trigger).
INGEST_SECRET=

# Optional. From newsdata.io — supplements the RSS feeds for
# tamilnadu/sports/cinema/world (not india — see src/lib/ingest/newsdata.ts
# for why). Ingestion runs fine without this, just RSS-only.
NEWSDATA_API_KEY=

# Direct Postgres connection (Connection pooling -> Transaction mode URI from
# Settings -> Database -> Connect), used only by scripts/migrate.ts. Not
# needed at runtime.
SUPABASE_DB_URL=
