# Public site origin (no trailing slash) — used to build absolute URLs in
# /sitemap.xml. Falls back to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=

# Supabase project: https://supabase.com/dashboard/project/bzjcenxqanzrezviqnsw
# Settings -> API for these values.

# Public — safe to expose to the browser, protected by RLS.
NEXT_PUBLIC_SUPABASE_URL=https://bzjcenxqanzrezviqnsw.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Secret — server-only, bypasses RLS. Used by scripts/seed.ts and the RSS
# ingestion pipeline. Never expose to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret required in the `x-ingest-secret` header to trigger
# POST /api/ingest (the RSS ingestion pipeline's remote trigger).
INGEST_SECRET=

# Optional. From newsdata.io — supplements the RSS feeds for
# tamilnadu/sports/cinema/world (not india — see src/lib/ingest/newsdata.ts
# for why). Ingestion runs fine without this, just RSS-only.
NEWSDATA_API_KEY=

# Direct Postgres connection (Connection pooling -> Transaction mode URI from
# Settings -> Database -> Connect), used only by scripts/migrate.ts. Not
# needed at runtime.
SUPABASE_DB_URL=

# Optional. From openweathermap.org (free tier) — powers the Chennai weather
# badge in the header. Badge just doesn't render without it.
OPENWEATHER_API_KEY=

# Optional. From cricapi.com (free tier) — powers the live cricket score row
# in the sidebar "LIVE அப்டேட்ஸ்" widget. Row just doesn't render without it.
CRICAPI_KEY=

# Optional. From ai.google.dev (Gemini API) — powers src/lib/ingest/images.ts:
# generates a stand-in illustration for articles ingested with no usable
# image (RSS/NewsData had none, and the og:image scrape also failed).
# Ingestion runs fine without it — those articles just get the site's
# generic placeholder graphic instead.
GEMINI_API_KEY=

# Required for /admin/poster (POST /api/generate-poster) — the social-media
# poster generator. From platform.openai.com; needs billing enabled (image
# generation isn't on the free tier). Model used: gpt-image-1-mini.
OPENAI_API_KEY=

# Shared password gating /admin/poster — every generation is a billed OpenAI
# call, so this isn't left open to anyone who finds the URL. Pick your own
# value; there's no format requirement.
POSTER_ADMIN_PASSWORD=
